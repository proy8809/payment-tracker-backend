{
	"info": {
		"name": "Payment Tracking",
		"description": "Payment Tracking Backend — Symfony 8.1 API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		}
	],
	"item": [
		{
			"name": "Health",
			"description": "Health check endpoint",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/hello",
					"host": ["{{base_url}}"],
					"path": ["api", "hello"]
				}
			},
			"response": [
				{
					"name": "OK",
					"status": "OK",
					"code": 200,
					"body": "{\n  \"data\": {\n    \"message\": \"Hello, World!\"\n  }\n}"
				}
			]
		},
		{
			"name": "Create User",
			"description": "Create a new user account",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"jane@example.com\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"password\": \"s3cret123\",\n  \"passwordConfirmation\": \"s3cret123\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/users",
					"host": ["{{base_url}}"],
					"path": ["users"]
				}
			},
			"response": [
				{
					"name": "Created",
					"status": "No Content",
					"code": 204,
					"body": ""
				},
				{
					"name": "Validation Error",
					"status": "Unprocessable Entity",
					"code": 422,
					"body": "{\n  \"error\": {\n    \"status\": 422,\n    \"code\": \"VALIDATION_ERROR\",\n    \"message\": \"Validation failed\",\n    \"details\": {\n      \"email\": \"This value should not be blank.\"\n    }\n  }\n}"
				}
			]
		},
		{
			"name": "List Users",
			"description": "Get a paginated list of users",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/users?page=1&limit=10",
					"host": ["{{base_url}}"],
					"path": ["users"],
					"query": [
						{ "key": "page", "value": "1" },
						{ "key": "limit", "value": "10" }
					]
				}
			},
			"response": [
				{
					"name": "OK",
					"status": "OK",
					"code": 200,
					"body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"email\": \"jane@example.com\",\n      \"firstName\": \"Jane\",\n      \"lastName\": \"Doe\"\n    }\n  ],\n  \"meta\": {\n    \"currentPage\": 1,\n    \"perPage\": 10,\n    \"totalItems\": 1,\n    \"totalPages\": 1\n  }\n}"
				}
			]
		{
			"name": "Delete User",
			"description": "Delete a user account by ID",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"id\": 1\n}"
				},
				"url": {
					"raw": "{{base_url}}/users",
					"host": ["{{base_url}}"],
					"path": ["users"]
				}
			},
			"response": [
				{
					"name": "No Content",
					"status": "No Content",
					"code": 204,
					"body": ""
				},
				{
					"name": "Not Found",
					"status": "Not Found",
					"code": 404,
					"body": "{\n  \"error\": {\n    \"status\": 404,\n    \"code\": \"NOT_FOUND\",\n    \"message\": \"User with ID 1 not found.\"\n  }\n}"
				}
			]
		}
	]
}
